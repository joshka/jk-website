---
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = "jk is a log-first terminal UI for Jujutsu VCS. It renders Jujutsu log and diff output with change selection, inline descriptions, and manual refresh.",
} = Astro.props;

const is404 = Astro.url.pathname.replace(/\/$/, '') === '/404';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const baseWithoutSlash = base.slice(0, -1);
const canonicalBasePathScript = `if (location.pathname === '${baseWithoutSlash}') {
  location.replace('${base}' + location.search + location.hash);
}`;
---

<!doctype html>
<html lang="en" class="dark" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {!is404 && <link rel="canonical" href={canonicalURL} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {!is404 && <meta property="og:url" content={canonicalURL} />}
    <meta property="og:image" content={new URL(`${base}assets/jk-log.png`, Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline set:html={canonicalBasePathScript}></script>
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[60] focus:rounded-md focus:bg-panel focus:px-3 focus:py-2 focus:text-sm"
    >
      Skip to content
    </a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
