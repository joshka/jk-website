---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Glow from '../components/Glow.astro';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const asset = (path: string) => `${base}assets/${path}`;
const inlineParts = (text: string) =>
  text.split(/(`[^`]+`)/g).map((part) =>
    part.startsWith('`') && part.endsWith('`')
      ? { code: true, text: part.slice(1, -1) }
      : { code: false, text: part }
  );

const workflowItems = [
  {
    title: 'Start with jj output',
    body: 'Keep a compact `jj log`-like view open with the graph, revset, templates, wording, and colors your CLI already uses.',
  },
  {
    title: 'Refresh without restarting',
    body: 'Refresh after editor, IDE, or agent writes without quitting the TUI and re-running `jj log` every time.',
  },
  {
    title: 'Stay out of the way',
    body: 'Open details, diffs, prompts, and previews only when you ask for them, instead of keeping every pane visible.',
  },
];

const commandRows = [
  ['jk', 'Open the configured default `jj` command when it is log-like enough for navigation.'],
  ['jk log', 'Open the explicit log path.'],
  ['jk log -T <template>', 'Render with a selected `jj log` template while keeping semantic navigation stable.'],
  ['jk diff -r <revision>', 'Inspect one revision using the canonical `jj diff` shape.'],
  ['jk diff --from A --to B', 'Compare two revisions from marks, cursor context, or explicit CLI arguments.'],
  ['jk show <revision>', 'Inspect selected-change details with `jj show` output.'],
  ['jk status', 'Inspect repository status without leaving the focused TUI flow.'],
  ['jk -R /path/to/repo -n 20', 'Carry repository and limit context through generated `jj` commands.'],
];

const principleItems = [
  {
    title: 'Command fidelity',
    body: 'The long-term model is that `jj` commands become interactive `jk` commands, with confirmation and context by default.',
  },
  {
    title: 'Presentation fidelity',
    body: '`jk` should honor `jj` configuration for default commands, revsets, templates, graph style, colors, diff formats, and operation semantics.',
  },
  {
    title: 'Focused screens',
    body: 'The default stays compact: one refreshable view, with separate screens or overlays for details, diffs, prompts, and previews.',
  },
  {
    title: 'Safe recovery',
    body: 'The planned mutation loop puts command history, operation log, undo, redo, and recovery beside every write.',
  },
];

const roadmapItems = [
  {
    title: '0.3 Foundation',
    body: 'Normalize `JjCommandSpec`, generated help and hotbar data, view stacks, ordered marks, `V` View Options, and cancellable tasks.',
  },
  {
    title: '0.4 jj-shaped inspection',
    body: 'Add canonical diff forms, selected-change `show`, `status`, `evolog`, reusable display options, file navigation, and diff search.',
  },
  {
    title: '0.5 command mode and workspaces',
    body: 'Add `:` jj command mode, `!` external commands, searchable discovery, command history, and a `W` workspace screen.',
  },
  {
    title: '0.6 safe mutation core',
    body: 'Introduce Run Options, describe, new, commit, edit, rebase, abandon, command previews, command history, and operation recovery.',
  },
  {
    title: '0.7 content workflows',
    body: 'Use shared selector models for filesets, operations, refs, remotes, and workspaces before adding squash, split, restore, diffedit, and absorb.',
  },
  {
    title: '0.8 to 1.0 release readiness',
    body: 'Harden refs, remotes, hybrid rendering, config-fidelity tests, Betamax recordings, docs, and install paths before recommending it broadly.',
  },
];

const media = [
  { file: 'jk-homepage.gif', label: 'Homepage workflow animation', preview: 'jk-homepage.gif' },
  { file: 'jk-log.gif', label: 'Log workflow animation', preview: 'jk-log.png' },
  { file: 'jk-log.png', label: 'Log view' },
  { file: 'jk-log-selection.png', label: 'Selected change' },
  { file: 'jk-log-expanded.png', label: 'Expanded change details' },
  { file: 'jk-log-help.png', label: 'Log help overlay' },
  { file: 'jk-diff.gif', label: 'Diff workflow animation', preview: 'jk-diff.png' },
  { file: 'jk-diff.png', label: 'Diff view' },
  { file: 'jk-diff-help.png', label: 'Diff help overlay' },
  { file: 'jk-diff-search.png', label: 'Diff search' },
  { file: 'jk-diff-folded-hunk.png', label: 'Folded hunk' },
  { file: 'jk-diff-folded-file.png', label: 'Folded file' },
];
---

<BaseLayout title="jk - a jj-native TUI for Jujutsu VCS">
  <section class="relative overflow-x-clip border-b border-line">
    <Glow class="left-1/2 top-[-260px] h-[640px] w-[1500px] -translate-x-1/2 sm:w-[1800px]" />
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 bg-page-hero"></div>

    <Container class="relative pb-16 pt-10 sm:pb-16 sm:pt-12">
      <div class="hero-copy mx-auto w-full max-w-xs text-center sm:max-w-3xl">
        <h1 class="mx-auto max-w-xs text-3xl font-semibold leading-[1.08] tracking-tight text-fg sm:max-w-3xl sm:text-balance sm:text-6xl">
          <span class="block sm:inline">A jj-native TUI</span>{' '}
          <span class="block sm:inline">for</span>{' '}
          <span class="block text-gradient sm:inline">Jujutsu VCS</span>
        </h1>

        <p class="mx-auto mt-4 max-w-xs text-pretty text-base leading-relaxed text-fg-2 sm:max-w-2xl sm:text-lg">
          <code>jk</code> is an early jj-native TUI experiment that keeps Jujutsu's configured
          <code>log</code> output open and refreshable beside your editor, IDE, or coding agent,
          then threads focused navigation and inspection through it.
        </p>

      </div>

      <div class="relative mx-auto mt-8 w-full max-w-full sm:max-w-5xl">
        <div class="glass relative overflow-hidden rounded-xl shadow-2xl shadow-black/50">
          <a
            href={asset('jk-homepage.gif')}
            class="block focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-brand"
          >
            <img
              src={asset('jk-homepage.gif')}
              alt="jk workflow animation showing log navigation, expanded details, diff review, help, search, folding, and refresh"
              width="1200"
              height="720"
              class="block w-full max-w-full"
              loading="eager"
            />
          </a>
        </div>
      </div>
    </Container>
  </section>

  <section id="install" class="border-b border-line bg-ink py-16 sm:py-24">
    <Container>
      <div class="max-w-3xl">
        <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">Install</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-fg sm:text-4xl">Install</h2>
        <p class="mt-4 text-lg leading-8 text-fg-2">
          Install from Josh's Homebrew tap on macOS, or use cargo-binstall for prebuilt Rust
          release archives on macOS and Linux.
        </p>
        <p class="mt-4 text-sm leading-6 text-fg-3">
          This is still early project work. Try it if the direction is interesting, but expect
          rough edges and missing workflow coverage.
        </p>
      </div>
      <div class="mt-10 grid gap-4 lg:grid-cols-3">
        <article class="rounded-lg border border-line bg-panel p-6">
          <div class="flex items-center justify-between gap-4">
            <p class="text-sm font-semibold text-fg">Homebrew on macOS</p>
            <button
              type="button"
              class="copy-command shrink-0 rounded border border-line px-2.5 py-1 text-xs font-semibold text-fg-2 transition-colors hover:border-brand hover:text-fg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
              data-command={`brew trust --formula joshka/tap/jk
brew install joshka/tap/jk`}
              aria-label="Copy Homebrew install commands"
            >
              Copy
            </button>
          </div>
          <div class="mt-4 rounded-md bg-ink">
            <pre class="overflow-x-auto px-3 py-3 font-mono text-[13px] leading-6 text-command"><code>brew trust --formula joshka/tap/jk
brew install joshka/tap/jk</code></pre>
          </div>
          <p class="mt-4 text-sm leading-6 text-fg-2">
            The trust step follows the
            <a
              href="https://github.com/joshka/homebrew-tap"
              class="text-fg underline decoration-line-2 underline-offset-[3px] transition-colors hover:text-accent"
            >
              joshka/homebrew-tap
            </a>
            install pattern.
          </p>
        </article>
        <article class="rounded-lg border border-line bg-panel p-6">
          <div class="flex items-center justify-between gap-4">
            <p class="text-sm font-semibold text-fg">cargo-binstall</p>
            <button
              type="button"
              class="copy-command shrink-0 rounded border border-line px-2.5 py-1 text-xs font-semibold text-fg-2 transition-colors hover:border-brand hover:text-fg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
              data-command="cargo binstall jk"
              aria-label="Copy cargo-binstall command"
            >
              Copy
            </button>
          </div>
          <div class="mt-4 rounded-md bg-ink">
            <pre class="overflow-x-auto px-3 py-3 font-mono text-[13px] leading-6 text-command"><code>cargo binstall jk</code></pre>
          </div>
          <p class="mt-4 text-sm leading-6 text-fg-2">
            Uses the published <code>jk</code> binary archive when your platform is supported.
          </p>
        </article>
        <article class="rounded-lg border border-line bg-panel p-6">
          <div class="flex items-center justify-between gap-4">
            <p class="text-sm font-semibold text-fg">From source</p>
            <button
              type="button"
              class="copy-command shrink-0 rounded border border-line px-2.5 py-1 text-xs font-semibold text-fg-2 transition-colors hover:border-brand hover:text-fg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
              data-command="cargo install jk --locked"
              aria-label="Copy source install command"
            >
              Copy
            </button>
          </div>
          <div class="mt-4 rounded-md bg-ink">
            <pre class="overflow-x-auto px-3 py-3 font-mono text-[13px] leading-6 text-command"><code>cargo install jk --locked</code></pre>
          </div>
          <p class="mt-4 text-sm leading-6 text-fg-2">
            Falls back to a normal crates.io build when you want Cargo to compile locally.
          </p>
        </article>
      </div>
    </Container>
  </section>

  <script>
    document.querySelectorAll<HTMLButtonElement>('.copy-command').forEach((button) => {
      const label = button.textContent?.trim() ?? 'Copy';
      button.addEventListener('click', async () => {
        const command = button.dataset.command;
        if (!command) return;

        await navigator.clipboard.writeText(command);
        button.textContent = 'Copied';
        window.setTimeout(() => {
          button.textContent = label;
        }, 1600);
      });
    });
  </script>

  <section id="workflow" class="border-b border-line bg-ink py-16 sm:py-24">
    <Container>
      <div class="max-w-3xl">
        <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">Workflow</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-fg sm:text-4xl">
          Refresh jj log in place.
        </h2>
        <p class="mt-4 text-lg leading-8 text-fg-2">
          The first screen is the view you would reach for with <code>jj log</code>, kept open in a
          terminal you can refresh after your editor, IDE, or agent changes the repository. The
          point is to avoid quitting and re-running commands without taking over the terminal with a
          permanent pane layout.
        </p>
      </div>

      <div class="mt-10 grid gap-4 md:grid-cols-3">
        {
          workflowItems.map(({ title, body }) => (
            <article class="rounded-lg border border-line bg-panel p-6">
              <h3 class="text-lg font-semibold text-fg">{title}</h3>
              <p class="mt-3 text-sm leading-6 text-fg-2">
                {
                  inlineParts(body).map((part) =>
                    part.code ? <code>{part.text}</code> : <>{part.text}</>
                  )
                }
              </p>
            </article>
          ))
        }
      </div>
    </Container>
  </section>

  <section class="border-b border-line bg-ink-2 py-16 sm:py-24">
    <Container>
      <div class="max-w-3xl">
        <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">Design constraints</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-fg sm:text-4xl">
          A refreshable jj view first.
        </h2>
        <p class="mt-4 text-lg leading-8 text-fg-2">
          <code>jk</code> follows Jujutsu's command model and configuration first. It starts from
          the output you already trust: your revsets, templates, graph style, colors, and diff
          preferences. Interactivity should make that output easier to keep open, inspect, and act
          from.
        </p>
        <p class="mt-4 text-lg leading-8 text-fg-2">
          A core tenet is that <code>jj</code> commands should have an interactive
          <code>jk</code> shape: resolve the objects from the current view, show the command and
          consequences, confirm before mutating, then refresh and leave a recovery path.
        </p>
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          principleItems.map(({ title, body }) => (
            <article class="rounded-lg border border-line bg-panel p-6">
              <h3 class="text-lg font-semibold text-fg">{title}</h3>
              <p class="mt-3 text-sm leading-6 text-fg-2">
                {
                  inlineParts(body).map((part) =>
                    part.code ? <code>{part.text}</code> : <>{part.text}</>
                  )
                }
              </p>
            </article>
          ))
        }
      </div>
    </Container>
  </section>

  <section class="border-b border-line bg-ink-2 py-16 sm:py-24">
    <Container class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">Diff review</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-fg sm:text-4xl">
          Inspect with jj-shaped commands.
        </h2>
        <p class="mt-4 text-lg leading-8 text-fg-2">
          <code>jk diff</code> opens rendered <code>jj diff</code> output for the current change,
          one revision, or a future marked range. The same inspection model grows to
          <code>show</code>, <code>status</code>, <code>evolog</code>, file navigation, and
          two-revision comparisons.
        </p>
      </div>
      <img
        src={asset('jk-diff.png')}
        alt="jk diff review workflow"
        width="1200"
        height="720"
        class="w-full rounded-lg border border-line-2 shadow-terminal"
        loading="lazy"
      />
    </Container>
  </section>

  <section id="roadmap" class="border-b border-line bg-ink py-16 sm:py-24">
    <Container class="grid gap-10 lg:grid-cols-[0.75fr_1.25fr]">
      <div>
        <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">Roadmap</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-fg sm:text-4xl">
          Planned command coverage.
        </h2>
        <p class="mt-4 text-lg leading-8 text-fg-2">
          The roadmap groups work by reusable command parts: global options, view options, run
          options, selectors, command mode, workspaces, mutation previews, operation recovery, refs,
          remotes, and recorded terminal fixtures.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href="https://github.com/joshka/jk/blob/main/docs/product-plan.md"
            class="rounded border border-line px-3 py-2 text-sm font-semibold text-fg-2 transition-colors hover:border-brand hover:text-fg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
          >
            Product plan
          </a>
          <a
            href="https://github.com/joshka/jk/blob/main/docs/roadmap.md"
            class="rounded border border-line px-3 py-2 text-sm font-semibold text-fg-2 transition-colors hover:border-brand hover:text-fg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
          >
            Roadmap doc
          </a>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {
          roadmapItems.map(({ title, body }) => (
            <article class="rounded-lg border border-line bg-panel p-6">
              <h3 class="text-lg font-semibold text-fg">{title}</h3>
              <p class="mt-3 text-sm leading-6 text-fg-2">
                {
                  inlineParts(body).map((part) =>
                    part.code ? <code>{part.text}</code> : <>{part.text}</>
                  )
                }
              </p>
            </article>
          ))
        }
      </div>
    </Container>
  </section>

  <section id="commands" class="border-b border-line bg-ink-2 py-16 sm:py-24">
    <Container class="grid gap-10 lg:grid-cols-[0.75fr_1.25fr]">
      <div>
        <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">Commands</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-fg sm:text-4xl">
          CLI surface follows jj shapes.
        </h2>
        <p class="mt-4 text-lg leading-8 text-fg-2">
          Bare <code>jk</code> follows <code>jj</code>'s configured default command when it is
          log-like enough for semantic navigation. Explicit commands keep canonical
          <code>jj</code> argument shapes visible so the TUI, command history, previews, and docs
          can all talk about the same command.
        </p>
        <p class="mt-4 text-sm leading-6 text-fg-3">
          These are the command shapes the product plan is standardizing around. The goal is not a
          separate command language; it is <code>jj</code> commands with selection, prompts,
          confirmation, output, refresh, and recovery built into the TUI.
        </p>
      </div>
      <div class="overflow-hidden rounded-lg border border-line bg-panel">
        {
          commandRows.map(([command, description]) => (
            <div class="grid gap-3 border-b border-line p-4 last:border-b-0 sm:grid-cols-[15rem_1fr]">
              <code class="font-mono text-sm text-command">{command}</code>
              <p class="text-sm leading-6 text-fg-2">
                {
                  inlineParts(description).map((part) =>
                    part.code ? <code>{part.text}</code> : <>{part.text}</>
                  )
                }
              </p>
            </div>
          ))
        }
      </div>
    </Container>
  </section>

  <section id="motivation" class="border-b border-line bg-ink py-16 sm:py-24">
    <Container class="grid gap-10 lg:grid-cols-[0.72fr_1.28fr]">
      <div>
        <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">Motivation</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-fg sm:text-4xl">
          Keep your jj view in context.
        </h2>
      </div>

      <div class="space-y-6 text-lg leading-8 text-fg-2">
        <p>
          <code>jk</code> starts from a common <code>jj</code> workflow: keep
          <code>jj log</code> visible while the repository changes somewhere else. The other writer
          might be an editor, a split terminal, an IDE, or a coding agent. Without a refreshable
          view, you quit the log, rerun it, and find your place again.
        </p>
        <p>
          The TUI should still feel like <code>jj</code>. It should use your revsets, colors,
          templates, graph style, and output preferences instead of replacing them with a parallel
          display model. The first job is to keep configured command output on screen and make it
          easier to navigate.
        </p>
        <p>
          That requirement keeps the layout small. <code>jk</code> starts from one compact view and
          adds detail when you ask for it: inline expansion, detail screens, overlays, prompts, and
          command previews. Split layouts can be useful, but the default should not require pane
          focus, pane resizing, or scanning several regions just to keep up with repository state.
        </p>
        <p>
          Command coverage should grow from the same rule. A <code>jj</code> command should have
          some <code>jk</code> path: direct action, menu item, prompt, command mode, or dedicated
          view. The TUI adds interaction around the command: selected objects, the exact command to
          run, confirmation for risky changes, refresh after completion, and a route to operation
          recovery.
        </p>
      </div>
    </Container>
  </section>

  <section id="media" class="bg-ink py-16 sm:py-24">
    <Container>
      <div class="max-w-3xl">
        <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">Media</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-fg sm:text-4xl">
          Work-in-progress screenshots
        </h2>
        <p class="mt-4 text-lg leading-8 text-fg-2">
          These are development captures, not a finished product tour. They show current log and
          diff rendering; keys, labels, command coverage, and layout may change.
        </p>
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          media.map(({ file, label, preview = file }) => (
            <a
              href={asset(file)}
              class="group block overflow-hidden rounded-lg border border-line bg-panel transition-colors hover:border-line-2 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
            >
              <img
                src={asset(preview)}
                alt={label}
                width="1200"
                height="720"
                loading="eager"
                class="aspect-video w-full object-cover"
              />
              <div class="flex min-h-16 items-center justify-between gap-3 px-4 py-3">
                <div>
                  <p class="text-sm font-medium text-fg">{label}</p>
                  <p class="mt-1 font-mono text-xs text-fg-3">{file}</p>
                </div>
                <span class="text-sm text-fg-3 transition-colors group-hover:text-fg">Open</span>
              </div>
            </a>
          ))
        }
      </div>
    </Container>
  </section>
</BaseLayout>
