---
import Container from './Container.astro';
import Logo from './Logo.astro';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const columns = [
  {
    title: 'Site',
    links: [
      { label: 'Install', href: `${base}#install` },
      { label: 'Workflow', href: `${base}#workflow` },
      { label: 'Roadmap', href: `${base}#roadmap` },
      { label: 'Commands', href: `${base}#commands` },
      { label: 'Screenshots', href: `${base}#media` },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'jk repository', href: 'https://github.com/joshka/jk' },
      { label: 'Jujutsu', href: 'https://github.com/jj-vcs/jj' },
    ],
  },
];
---

<footer class="border-t border-line bg-ink-2">
  <Container class="py-14">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr_1fr]">
      <div>
        <Logo />
        <p class="mt-3 max-w-xs text-sm leading-relaxed text-fg-3">
          A log-first terminal UI for Jujutsu that preserves the <code>jj</code> output you already trust.
        </p>
      </div>
      {
        columns.map(({ title, links }) => (
          <nav aria-label={title}>
            <p class="text-[13px] font-semibold tracking-wide text-fg">{title}</p>
            <ul class="mt-4 space-y-2.5">
              {links.map(({ label, href }) => (
                <li>
                  <a href={href} class="text-sm text-fg-2 transition-colors hover:text-fg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand">
                    {label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-line pt-6 sm:flex-row sm:items-center">
      <p class="text-[13px] text-fg-3">© {new Date().getFullYear()} Josh McKinney.</p>
      <p class="text-[13px] text-fg-3">Screenshots</p>
    </div>
  </Container>
</footer>
