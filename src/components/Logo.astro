---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

// Unique per render because the logo is mounted in both Nav and Footer.
const gradientId = `logo-grad-${crypto.randomUUID().slice(0, 8)}`;
---

<a href={base} class={`group inline-flex items-center gap-2 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand ${className}`}>
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <defs>
      <linearGradient id={gradientId} x1="0" y1="0" x2="24" y2="24">
        <stop offset="0%" stop-color="var(--color-brand-bright)"></stop>
        <stop offset="100%" stop-color="var(--color-accent)"></stop>
      </linearGradient>
    </defs>
    <path
      d="M4 5.5A2.5 2.5 0 0 1 6.5 3h11A2.5 2.5 0 0 1 20 5.5v13a2.5 2.5 0 0 1-2.5 2.5h-11A2.5 2.5 0 0 1 4 18.5v-13Z"
      fill={`url(#${gradientId})`}></path>
    <path d="M8 8.25h5.25M8 12h8M8 15.75h4.5" stroke="#0a0a0f" stroke-width="1.7" stroke-linecap="round"></path>
  </svg>
  <span class="text-[15px] font-semibold tracking-tight text-fg">jk</span>
</a>
