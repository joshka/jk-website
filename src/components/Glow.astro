---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div
  aria-hidden="true"
  class={`pointer-events-none absolute select-none ${className}`}
  style="background:
    radial-gradient(ellipse at 50% 18%, rgb(45 83 180 / 0.34) 0%, rgb(20 53 108 / 0.20) 34%, transparent 64%),
    radial-gradient(ellipse at 18% 46%, rgb(20 102 145 / 0.22) 0%, transparent 50%),
    radial-gradient(ellipse at 82% 44%, rgb(20 112 152 / 0.20) 0%, transparent 52%);
  filter: blur(58px);"
>
</div>
