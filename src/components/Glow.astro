---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div
  aria-hidden="true"
  class={`pointer-events-none absolute select-none ${className}`}
  style="background:
    radial-gradient(ellipse at 50% 18%, rgb(92 66 190 / 0.34) 0%, rgb(38 40 105 / 0.18) 32%, transparent 62%),
    radial-gradient(ellipse at 18% 46%, rgb(28 105 130 / 0.20) 0%, transparent 48%),
    radial-gradient(ellipse at 82% 44%, rgb(31 103 130 / 0.18) 0%, transparent 50%);
  filter: blur(58px);"
>
</div>
